#include <stdio.h>
int findGCD(int a, int b) {
    if (b != 0)
        return findGCD(b, a % b);
    else
        return a;
}
int main() {
    int n1, n2;
    printf("Enter two positive integers: ");
    scanf("%d %d", &n1, &n2);
    printf("GCD of %d and %d is %d.", n1, n2, findGCD(n1, n2));
    printf("\nREG NO:25331A05I5");
    return 0;
}
